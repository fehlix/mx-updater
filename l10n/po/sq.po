#. TRANSLATORS: The string "MX Updater" is the name of the tool that
#. appears in the system tray/taskbar to inform users about software
#. package updates and perform various actions to update and upgrade the
#. system.  The string is used in various places. Keep the translation
#. short and leave the string "MX Updater" untranslated if necessary.
msgid "MX Updater"
msgstr "Përditësues MX"

#. TRANSLATORS: The desktop entry comment will be shown within the menu.
#. Keep it short.
msgid "MX Updater system tray applet"
msgstr "Aplikacionth “Përditësues MX” për panel sistemi"

#. TRANSLATORS: Keywords for Menu Search
#. Important Translation Guidance:
#. - Keep the original English keywords
#. - Add translated keywords
#. - IMPORTANT: End EACH keyword with a semicolon (;)
#. - Do NOT replace English keywords entirely
#. Example:
#. English keywords: "repository;update;upgrade;"
#. French keywords: "repository;update;upgrade;référentiel;mise à jour;mise à
#. niveau;"
#. Note the inclusion of:
#. - Accented characters (à, é)
#. - Non-ASCII translations
#. - Original English keywords preserved
#. - Each keyword ending with a semicolon
msgid ""
"apt;install;mxpi;nala;notifier;software;package;repo;synaptic;unattended;update;"
msgstr ""
"apt;instalim;mxpi;nala;njoftues;software;paketë;depo;synaptic;pa "
"prani;përditësim;"

#. TRANSLATORS: The string "MX Updater Settings" is the desktop entry name
#. displayed in the menu.
msgid "MX Updater Settings"
msgstr "Rregullime Përditësuesi MX"

#. TRANSLATORS: The string "MX Updater preferences" is desktop entry comment
#. of the ""MX Updater Settings" menu entry.
msgid "MX Updater preferences"
msgstr "Parapëlqime Përditësuesi MX"

#. TRANSLATORS: The autostart desktop entry name will be shown within the list
#. of autostart entries.
msgid "MX Updater Autostart"
msgstr "Vetënisje Përditësuesi MX"

#. TRANSLATORS: The autostart desktop entry comment will be shown within
#. 'Session and Startup' (Autostart).
msgid "An applet to show updates"
msgstr "Një aplikacion i vockël për të shfaqur përditësime"

#. TRANSLATORS: The string is displayed within the authentication window to
#. disable unattended-upgrade (Auto-update)!
msgid "Disable Auto-update"
msgstr "Çaktivizo Vetëpërditësime"

#. TRANSLATORS: The string is displayed within the authentication window to
#. enable unattended-upgrade (Auto-update)!
msgid "Enable Auto-update"
msgstr "Aktivizo Vetëpërditësime"

#. TRANSLATORS: Shown in the polkit authentication dialog when the user
#. changes the automatic refresh/upgrade interval.
msgid "Set automatic refresh/upgrade interval"
msgstr ""

#. TRANSLATORS: The upgrade mode "basic upgrade".
msgid "basic upgrade"
msgstr "përmirësim elementar"

#. TRANSLATORS: The upgrade mode "full upgrade".
msgid "full upgrade"
msgstr "përmirësim i plotë"

#. TRANSLATORS: To "reload"/"refresh" the package cache with "apt-get update"
msgid "Reload"
msgstr "Ringarkoje"

msgid "Press 'h' for help, 'q' to quit"
msgstr "Shtypni “h” për ndihmë, “q” për mbyllje"

msgid "No logs found."
msgstr "S’u gjetën regjistra."

msgid "For a less detailed view see 'Auto-update dpkg log(s)' or 'History'."
msgstr ""
"Për një pamje më pak të hollësishme, shihni “Regjistër(a) dpkg auto-update”,"
" ose “Historik”."

msgid "No updates available"
msgstr "S’ka përditësime gati"

#. TRANSLATORS: Plural Forms Guide
#. Each language has unique rules for plurals. Fill in ALL plural forms
#. specified for your language.
#. - "%d" will be replaced by the actual number at runtime
#. - Use grammatically correct translations for each form
#. - Singular form (msgstr[0]): Typically for count of 1
#. - Plural forms (msgstr[1], msgstr[2], etc.): Use appropriate grammatical
#. variations
#. Example (English):
#. msgstr[0] "One new update"
#. msgstr[1] "%d new updates"
#. Tip: Consider your language's specific plural formation rules and
#. grammatical nuances.
msgid "%d new update available"
msgid_plural "%d new updates available"
msgstr[0] "%d përditësim i ri i gatshëm"
msgstr[1] "%d përditësime të reja të gatshme"

msgid "basic upgrade complete (or was canceled)"
msgstr "përmirësim elementar i plotësuar (ose u anulua)"

msgid "full upgrade complete (or was canceled)"
msgstr "përmirësim tërësor i plotësuar (ose u anulua)"

msgid "this terminal window can now be closed"
msgstr "kjo dritare terminali tani mund të mbyllet"

msgid "press any key to stop automatic closing"
msgstr "shtypni çfarëdo tasti, për të ndalur mbylljen automatike"

msgid "press any key to close"
msgstr "shtypni çfarëdo tasti që të mbyllet"

#. TRANSLATORS: This is the first line of the tooltip of the
#. button with an arrorw down symbol to jump to the next found "search string"
msgid "Find Next"
msgstr "Gjej Pasuesen"

#. TRANSLATORS: This is the first line of the tooltip of the
#. button with an arrorw up symbol to jump to the previous found "search
#. string"
msgid "Find Previous"
msgstr "Gjej të Mëparshmen"

#. TRANSLATORS: This is the first line of the tooltip of the
#. button with a symbol "[Aa]" to toggle on/off case sensitive search.
msgid "Match Case"
msgstr "Siç Është Shkruar"

#. TRANSLATORS: This is the first line of the tooltip of the
#. button with an ellipsis symbol "[...]" to toggle "whole word" search.
msgid "Whole Word"
msgstr "Krejt Fjalën"

#. TRANSLATORS: This is the first line of the tooltip of the
#. button with an "star" symbol "[*]" to toggle highlight of all searches
#. found.
msgid "Mark All"
msgstr "Vëru Shenjë të Tërave"

#. TRANSLATORS: This is the string used to label the "Ctrl" key on the
#. keyboard.
msgid "Ctrl"
msgstr "Ctrl"

#. TRANSLATORS: This is the string used to label the "Shift" key on the
#. keyboard.
msgid "Shift"
msgstr "Shift"

#. TRANSLATORS: This is the placeholder string shown within in the search
#. field.
#. The string is also shown as the first line within the tooltip.
msgid "Search..."
msgstr "Kërkoni…"

#. TRANSLATORS: This is the title of the popup window indicating that the
#. search string was not found.
msgid "Not Found"
msgstr "S’u Gjet"

#. TRANSLATORS: This is the text shown within the Not-found  popup window.
#. The token '%(s)s' will be replaced with the search text at runtime.
msgid "\"%(s)s\" was not found."
msgstr "“%(s)s” s’u gjet."

msgid "MX Auto-update  --  unattended-upgrades dpkg log viewer"
msgstr ""
"MX Auto-update  --  parës regjistri dpkg përmirësimesh të pambikëqyrura"

msgid "Auto-update dpkg log(s)"
msgstr "Vetëpërditëso regjistër(a) dpkg"

msgid "MX Auto-update  --  unattended-upgrades log viewer"
msgstr "MX Auto-update  --  parës regjistri përmirësimesh të pambikëqyrura"

msgid "Auto-update log(s)"
msgstr "Regjistër(a) vetëpërditësimi"

msgid "Tray applet to notify of system and application updates"
msgstr ""
"Aplikacionth paneli, për të njoftuar rreth përditësimesh sistemi dhe "
"aplikacionesh"

msgid "About MX Updater"
msgstr "Mbi Përditësuesin MX"

msgid "Close"
msgstr "Mbylle"

msgid "License"
msgstr "Licencë"

msgid "Changelog"
msgstr "Regjistër ndryshimesh"

#. TRANSLATORS: "History" menu item in right-click context
#. Allows users to view logs of package installations and removals
#. using dpkg and apt package management tools
msgid "History"
msgstr "Historik"

msgid "No apt-history data found!"
msgstr "S’u gjetën të dhëna për apt-history!"

msgid "Error retrieving apt-history:"
msgstr "Gabim në marrje të apt-history:"

msgid "Preferences"
msgstr "Parapëlqime"

#. TRANSLATORS: The label group-box, where user can select
#. the "Upgrade mode" either "full upgrade" or "basic upgrade"
msgid "Upgrade mode"
msgstr "Mënyrë përmirësimi"

#. TRANSLATORS: The label of the radio button for "full" upgrade mode.
msgid "full"
msgstr ""

#. TRANSLATORS: The tooltip of the radio button "full" (full upgrade,
#. recommended).
msgid ""
"Upgrades all packages to their latest versions,\n"
"which may include adding or removing packages\n"
"to keep the system up-to-date and consistent."
msgstr ""
"Përmirëson krejt paketat me versionet e tyre më\n"
"të reja, çka mund të përfshijë shtim ose heqje\n"
"paketash, për ta mbajtur sistemin të përditësuar\n"
"dhe të qëndrueshëm."

#. TRANSLATORS: The upgrade mode "full upgrade (recommended)".
msgid "full upgrade   (recommended)"
msgstr "përmirësim i plotë   (e rekomanduar)"

#. TRANSLATORS: The label of the radio button for "basic" upgrade mode.
msgid "basic"
msgstr ""

#. TRANSLATORS: The tooltip of the checkbox "basic upgrade",
#. which tries to explain what this checkbox is about.
msgid ""
"Upgrades existing packages to their latest versions\n"
"without installing new dependencies or removing existing packages."
msgstr ""
"Përmirëson paketat ekzistuese me versionet e tyre\n"
"më të reja, pa instaluar varësi të reja, apo hequr paketa ekzistuese."

#. TRANSLATORS: The label of the checkbox, where user can select
#. to use "nala" package manager instead of "apt"
#. TRANSLATORS: Select this to use nala package manager instead of apt.
msgid "use nala"
msgstr "përdor nala-n"

#. TRANSLATORS: The tooltip of the checkbox "nala",
#. which tries to explain what this checkbox is about.
#. TRANSLATORS: Explains upgrade can be done by using nala package manager
#. instead of apt
msgid "Select this to use nala package manager instead of apt."
msgstr ""
"Përzgjidhni këtë, që të përdoret përgjegjësi nala i paketave, në vend se "
"apt."

msgid "daily"
msgstr ""

msgid "every 3 days"
msgstr "çdo 3 ditë"

msgid "weekly"
msgstr "çdo javë"

msgid "every 2 weeks"
msgstr "çdo 2 javë"

msgid "monthly"
msgstr "çdo muaj"

msgid "never"
msgstr "kurrë"

#. TRANSLATORS: Label of the checkbox to enable unattended (automatic) package
#. upgrades.
#. "automatic upgrade" = unattended upgrade running at the interval set in the
#. refresh selector.
#. Note: many languages use the same word for English "update" and "upgrade"
#. -- use whichever
#. word in your language best describes "installing newer versions of existing
#. packages".
msgid "automatic upgrade"
msgstr "përmirësim i automatizuar"

#. TRANSLATORS: Old label of the automatic upgrade checkbox -- kept for
#. translators reference.
msgid "automatic"
msgstr "i automatizuar"

#. TRANSLATORS: Old label of the automatic upgrade checkbox -- kept for
#. translators reference.
msgid "upgrade automatically"
msgstr "përmirësoje automatikisht"

#. TRANSLATORS: Old tooltip of the "automatic upgrade" checkbox -- kept for
#. translators reference.
msgid ""
"Automatically check for package updates once a day and install them.\n"
"Only updates existing packages without changing your system configuration.\n"
"The updater icon shows the total number of updates, including automatic updates,\n"
"when additional updates are available."
msgstr ""
"Kontrollo automatikisht një herë në ditë për përditësime paketash dhe instaloji.\n"
"Përditësim vetëm paketa ekzistuese, pa ndryshuar formësimin tuaj të sistemit.\n"
"Ikona e përditësuesit shfaq numrin gjithsej të përditësimeve, përfshi përditësime\n"
"të automatizuara, kur ka përditësime shtesë."

msgid ""
"Automatically install package upgrades at the interval set in the refresh selector.\n"
"Only upgrades existing packages without changing your system configuration.\n"
"The updater icon shows the total number of updates, including automatic upgrades,\n"
"when additional updates are available."
msgstr ""
"Instalo automatikisht në intervalin e caktuar te përzgjedhësi i rifreskimeve\n"
"përmirësime paketash.\n"
"Përmirëson vetëm paketa ekzistuese, pa ndryshuar formësimin tuaj të sistemit.\n"
"Ikona e përditësuesit shfaq numrin gjithsej të përditësimeve, përfshi përmirësime\n"
"të automatizuara, kur ka përditësime shtesë."

#. TRANSLATORS: Label shown before the interval dropdown in the Upgrade mode
#. section.
#. "refresh" = package list refresh (apt-get update). The selected interval
#. also applies
#. to automatic upgrades when the "automatic upgrade" checkbox is checked.
msgid "refresh"
msgstr "rifreskoje"

msgid ""
"Sets how often the package list is refreshed (apt-get update).\n"
"The same interval applies to automatic upgrades when\n"
"\"automatic upgrade\" is checked."
msgstr ""

msgid "Left-click"
msgstr ""

#. TRANSLATORS: The label of the group box for left-click behaviour.
msgid "Left-click behaviour   (when updates are available)"
msgstr "Sjellje e klikimit me të majtin (kur ka përditësime)"

msgid ""
"Left-click opens the selected application.\n"
"Middle-click opens MX Package Installer\n"
"(or Synaptic if MX Package Installer is not installed).\n"
"Middle-click does nothing if neither is installed."
msgstr ""

msgid "opens Synaptic"
msgstr "hap Synaptic-un"

msgid ""
"Left-click always opens Synaptic package manager,\n"
"with or without updates available."
msgstr ""

msgid ""
"Left-click always opens MX Package Installer (MXPI),\n"
"with or without updates available."
msgstr ""

#. TRANSLATORS: The label of the radio button to open the View and Upgrade
#. window on left-click.
msgid "View and Upgrade"
msgstr "Shiheni dhe Përmirësojeni"

msgid ""
"Left-click opens the \"View and Upgrade\" window\n"
"when updates are available.\n"
"When no updates are available, opens Synaptic\n"
"or MX Package Installer instead."
msgstr ""

#. TRANSLATORS: The label of the radio button "opens MX Updater 'View and
#. Upgrade' window".
msgid "opens MX Updater 'View and Upgrade' window"
msgstr "hap dritaren “Shiheni dhe Përmirësojeni” të Përditësuesit MX"

msgid "Icons"
msgstr "Ikona"

#. TRANSLATORS: Please keep it short. Detailed explanation is in the tooltip.
#. "dark/light" refers to the dark and light wireframe icon variants (the no-
#. updates
#. icons). The "some-updates" wireframe icon is always the green app icon,
#. unaffected.
msgid "transparent wireframe for no updates"
msgstr "kornizë e tejdukshme për kur s’ka përditësime"

#. TRANSLATORS: Short label for checkbox. "black/white" refers to the two
#. wireframe
#. no-updates icon variants (wireframe-dark has white wires, wireframe-light
#. has black wires).
#. Detailed explanation is in the tooltip.
msgid "transparent black/white wireframe"
msgstr ""

#. TRANSLATORS: Tooltip for "transparent black/white wireframe" checkbox.
#. Explains when transparent works and when it does not, depending on panel
#. color.
#. "wireframe-dark" has white wires; "wireframe-light" has black/dark wires.
msgid ""
"Make the black/white wireframe no-updates icon transparent (no color fill).\n"
"Works best when panel color contrasts with the wire color:\n"
"  wireframe-dark (white wires): visible on dark panel, invisible on light panel.\n"
"  wireframe-light (black wires): visible on light panel, invisible on dark panel."
msgstr ""

#. TRANSLATORS: The strings "dark" or "light" are used for the "dark" or
#. "light" icon-set, respectively.
msgid "dark"
msgstr "e errët"

#. TRANSLATORS: The strings "dark" or "light" are used for the "dark" or
#. "light" icon-set, respectively.
msgid "light"
msgstr "e çelët"

#. TRANSLATORS: The wireframe icon-set
msgid "wireframe"
msgstr "kornizë"

#. TRANSLATORS: The pulse icon-set
msgid "pulse"
msgstr "puls"

#. TRANSLATORS: The classic icon-set
msgid "classic"
msgstr "klasike"

msgid "Other options"
msgstr "Mundësi të tjera"

msgid "Other"
msgstr "Tjetër"

#. TRANSLATORS: The label of the checkbox, where user can select
#. that "--assume-yes" option is added, so "apt" or "nala" won't ask
#. for confirmations to install
msgid "skip upgrade confirmation"
msgstr ""

msgid "automatically confirm all package upgrades"
msgstr "ripoho automatikisht krejt përmirësimet e paketave"

#. TRANSLATORS: The tooltip of the checkbox "automatically confirm all package
#. upgrades",
#. which tries to explain what this checkbox is about.
msgid ""
"Automatically answers 'yes' to package management prompts during upgrades.\n"
"Some system configuration changes may still require manual confirmation."
msgstr ""
"Përgjigju automatikisht “po” pyetjes nga administrim paketash gjatë përmirësimesh.\n"
"Disa ndryshime formësimi sistemi mund të duan ende ripohim dorazi."

#. TRANSLATORS: The label of the checkbox where user can select
#. to start 'MX Updater' systray icon automatically at login
#. after a delay of seconds.
msgid "autostart delay"
msgstr ""

msgid "start \"MX Updater\" at login after delay"
msgstr "nise “Përditësuesin MX” gjatë hyrjes, pas vonese"

#. TRANSLATORS: Explains the start of MX Updater automatically
#. after a delay of seconds. The user can select the number of seconds.
msgid ""
"Select this to launch \"MX Updater\" automatically\n"
"at login after the specified delay in seconds."
msgstr ""
"Përzgjidheni këtë që “Përditësuesi MX” të niset\n"
"automatikisht në hyrje, pas vonesës së dhënë\n"
"në sekonda."

#. TRANSLATORS: This is the abbreviated string for "seconds" that appears
#. in the timeout/time delay selection field. Please use the most appropriate
#. translated string for the singular or plural form. Only one form will
#. be displayed.
msgid "sec"
msgstr "sek"

#. TRANSLATORS: After the idle time in seconds has elapsed,
#. the terminal window is closed once the system update is complete.
msgid "terminal auto-close"
msgstr ""

msgid "close terminal window after idle time"
msgstr "mbylle dritaren e terminalit pas kohe plogështie"

#. TRANSLATORS: Explains the auto-close behavior of terminal window
#. after system updates with a configurable idle time
msgid ""
"Automatically closes the terminal window after the specified\n"
"number of seconds of inactivity following system updates."
msgstr ""
"Bën mbylljen vetvetiu të dritares së terminalit pas numrit\n"
"të dhënë të sekondave plogështie në vijim të përditësimeve\n"
"të sistemit."

#. TRANSLATORS: Label before the terminal window size dropdown
msgid "terminal size"
msgstr ""

#. TRANSLATORS: terminal window size option: default auto-sizing (original
#. behavior, 2/3 screen capped on large displays)
msgid "default"
msgstr "parazgjedhje"

#. TRANSLATORS: terminal window size option: let terminal use its own saved
#. size/position
msgid "own"
msgstr ""

#. TRANSLATORS: terminal window size option: one third of the screen
msgid "1/3 screen"
msgstr ""

#. TRANSLATORS: terminal window size option: half the screen
msgid "1/2 screen"
msgstr ""

#. TRANSLATORS: terminal window size option: two thirds of the screen
msgid "2/3 screen"
msgstr ""

#. TRANSLATORS: terminal window size option: three quarters of the screen
msgid "3/4 screen"
msgstr ""

#. TRANSLATORS: terminal window size option: nine tenths of the screen
msgid "9/10 screen"
msgstr ""

#. TRANSLATORS: terminal window size option: full screen
msgid "full screen"
msgstr ""

#. TRANSLATORS: Label before the terminal window position dropdown
msgid "position"
msgstr ""

#. TRANSLATORS: terminal window position option
msgid "center"
msgstr "në qendër"

#. TRANSLATORS: terminal window position option
msgid "top-left"
msgstr ""

#. TRANSLATORS: terminal window position option
msgid "top-right"
msgstr ""

#. TRANSLATORS: terminal window position option
msgid "bottom-left"
msgstr ""

#. TRANSLATORS: terminal window position option
msgid "bottom-right"
msgstr ""

#. TRANSLATORS: Tooltip for the terminal window size label and dropdown.
#. "default (auto)" means the original automatic sizing is used.
msgid ""
"Terminal size and position for system updates:\n"
"\"default\": 2/3 screen size, capped at 960x600 pixels.\n"
"\"own\": use terminal's own settings for size and position."
msgstr ""

#. TRANSLATORS: Tooltip for the terminal window position dropdown.
#. The option is disabled when "full screen" size is selected, or on Wayland.
msgid ""
"Select where the terminal window appears on the screen.\n"
"Hidden when \"own\" or \"full screen\" size is selected, or when running on Wayland."
msgstr ""

#. TRANSLATORS: The label of the checkbox "desktop notifications",
#. where user can select to disabled or enable notification "popup" window
#. shown .
msgid "use desktop notifications"
msgstr "përdor njoftime desktopi"

#. TRANSLATORS: Short label for checkbox to enable or disable desktop
#. notification popups.
msgid "desktop notifications"
msgstr ""

#. TRANSLATORS: The tooltip of of the checkbox "use desktop notifications",
#. which tries to exlpain what this checkbox is about.
msgid ""
"In addition to change of the tray icon,\n"
"pop-up messages will be shown when\n"
"system updates are available."
msgstr ""
"Tej ndryshimit të ikonës së panelit,\n"
"do të shfaqen flluska mesazhesh, kur\n"
"të ketë gati përditësime sistemi."

#. TRANSLATORS: The label of the checkbox, where user can select to not show
#. the "MX Updater" systray icon when no package upgrades are available.
msgid "Hide until updates available"
msgstr "Fshihe, deri sa të ketë përditësime"

#. TRANSLATORS: Short label for checkbox. Hides the systray icon when no
#. package upgrades are available.
msgid "hide when no updates"
msgstr ""

#. TRANSLATORS: The tooltip of of the checkbox "hide until updates available",
#. which tries to exlpain what this checkbox is about.
msgid ""
"Hide the system update icon when no updates are available.\n"
"Untick this box or run \"MX Updater\" from the menu to make the icon visible again."
msgstr ""
"Fshihe ikonën e përditësimit të sistemit, kur s’ka përditësime gati.\n"
"Që ta bëni të dukshme sërish ikonën, hiqjani shenjën kësaj kutize,\n"
"ose xhirojeni “Përditësuesin MX” që nga menuja."

msgid "MX Updater Help"
msgstr "Ndihmë Përditësuesi MX"

msgid "Error"
msgstr "Gabim"

msgid "An unexpected error occurred:"
msgstr "Ndodhi një gabim i papritur:"

#. TRANSLATORS: Shown in the frequency combo when the current apt-config value
#. does not
#. match any preset (daily/weekly/etc). %s is a compact interval like "5d",
#. "12h", or "always".
msgid "custom (%s)"
msgstr ""

#. TRANSLATORS: One-line header in the frequency combo tooltip showing current
#. effective
#. apt-config values. First %s = refresh interval, second %s = upgrade
#. interval,
#. each wrapped in parentheses, e.g. "(daily)", "(5d)", "(always)", "(never)".
msgid "Current (apt-config): refresh %s, upgrade %s"
msgstr ""

msgid ""
"Sets the interval for package list refresh (apt-get update).\n"
"When 'automatic upgrade' is checked, the same interval also applies to the upgrade.\n"
"'never' disables both the refresh and the automatic upgrade."
msgstr ""

#. TRANSLATORS: Warning shown when a higher-priority apt configuration
#. overrides
#. the setting written by mx-updater. %s values are labels like "daily",
#. "never", "12h".
msgid ""
"Could not apply setting: a higher-priority apt configuration\n"
"is overriding the effective values.\n"
"\n"
"Requested: refresh %s, upgrade %s\n"
"Effective: refresh %s, upgrade %s"
msgstr ""

#. TRANSLATORS: Title of the warning dialog shown when an apt configuration
#. file
#. with higher priority is overriding the value written by mx-updater.
msgid "Setting Overridden"
msgstr ""

#. TRANSLATORS: Title of the error dialog shown when the pkexec action script
#. to set apt periodic upgrade configuration fails (non-zero exit).
msgid "Unattended Upgrades Configuration Failed"
msgstr "Formësimi i Përmirësimeve Pa Ndërhyrje Përdoruesi Dështoi"

#. TRANSLATORS: Body text of the error dialog for a failed apt periodic
#. configuration write.
msgid "Could not change automatic upgrades configuration"
msgstr "S’u ndryshua dot formësimi për përmirësime të automatizuara"

